# =============================================================================
# SYNKI - Hindi GF-style Voice Companion
# Environment Configuration
# =============================================================================

# LiveKit Configuration
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram Configuration (STT)
DEEPGRAM_API_KEY=your_deepgram_api_key

# OpenAI Configuration (LLM)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Cartesia Configuration (TTS)
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_selected_voice_id

# Redis Configuration (Memory/State)
REDIS_URL=redis://localhost:6379/0

# Application Settings
LOG_LEVEL=INFO
AGENT_NAME=synki-companion
DEBUG_MODE=false

# Persona Settings
DEFAULT_PERSONA=girlfriend
DEFAULT_LANGUAGE=hinglish

# Firebase Configuration (Push Notifications)
FIREBASE_PROJECT_ID=synciki
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"synciki","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-fbsvc@synciki.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40synciki.iam.gserviceaccount.com","universe_domain":"googleapis.com"}
