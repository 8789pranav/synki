# =============================================================================
# SYNKI - Hindi GF-style Voice Companion
# Environment Configuration
# =============================================================================

# LiveKit Configuration
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram Configuration (STT)
DEEPGRAM_API_KEY=your_deepgram_api_key

# OpenAI Configuration (LLM)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Cartesia Configuration (TTS)
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_selected_voice_id

# Redis Configuration (Memory/State)
REDIS_URL=redis://localhost:6379/0

# Application Settings
LOG_LEVEL=INFO
AGENT_NAME=synki-companion
DEBUG_MODE=false

# Persona Settings
DEFAULT_PERSONA=girlfriend
DEFAULT_LANGUAGE=hinglish
